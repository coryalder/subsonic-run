{% extends "picker.njk" %}

{% block header %}
    <h2>Playlists</h2>
{% endblock %}

{% block content %}
    <ul class="picker-grid">
        {% for playlist in playlists %}
            <li class="card" hx-get="/playlist/{{ playlist.id }}" hx-target="closest .picker-widget" hx-swap="outerHTML">
                <img src="/artwork/{{ playlist.coverArt }}" alt="{{ playlist.name }}" loading="lazy">
                <div class="card-title">{{ playlist.name }}</div>
                <div class="card-subtitle">{{ playlist.songCount }} songs</div>
            </li>
        {% else %}
            <li style="padding: 1rem; color: #666;">No playlists found.</li>
        {% endfor %}
    </ul>
{% endblock %}
