{% if not isPartial %}
{% extends "picker.njk" %}

{% block header %}
    <h2>{% if artist %}{{ artist.name }}{% else %}{{ title | default('Albums') }}{% endif %}</h2>
    {% if artist %}
    <button hx-get="/artists" hx-target="closest .picker-widget" hx-swap="outerHTML" style="font-size: 0.8rem;">&larr; Back</button>
    {% endif %}
{% endblock %}

{% block content %}
    <ul class="picker-list">
        {% for album in albums %}
            {% if loop.last and hasMore and not artist %}
            <li hx-get="/albums?offset={{ nextOffset }}" hx-trigger="revealed" hx-swap="afterend">
            {% else %}
            <li hx-get="/album/{{ album.id }}" hx-target="closest .picker-widget" hx-swap="outerHTML">
            {% endif %}
                <div class="picker-list-info">
                    <div class="picker-list-title">{{ album.title }}</div>
                    <div class="picker-list-subtitle">{{ album.year }}</div>
                </div>
                <div style="color: #ccc; font-size: 0.8rem;">&rsaquo;</div>
            </li>
        {% else %}
            <li style="padding: 1rem; color: #666;">No albums found.</li>
        {% endfor %}
    </ul>
{% endblock %}
{% else %}
    {% for album in albums %}
        {% if loop.last and hasMore and not artist %}
        <li hx-get="/albums?offset={{ nextOffset }}" hx-trigger="revealed" hx-swap="afterend">
        {% else %}
        <li hx-get="/album/{{ album.id }}" hx-target="closest .picker-widget" hx-swap="outerHTML">
        {% endif %}
            <div class="picker-list-info">
                <div class="picker-list-title">{{ album.title }}</div>
                <div class="picker-list-subtitle">{{ album.year }}</div>
            </div>
            <div style="color: #ccc; font-size: 0.8rem;">&rsaquo;</div>
        </li>
    {% endfor %}
{% endif %}
