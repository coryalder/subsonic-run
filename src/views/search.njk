{% extends "picker.njk" %}

{% block header %}
    <h2>Search results for "{{ query }}"</h2>
{% endblock %}

{% block content_attrs %}style="max-height: 500px; overflow-y: auto;"{% endblock %}

{% block content %}
    {% if artists.length > 0 %}
        <h3 style="padding: 0.5rem 1rem; font-size: 1rem; color: #666; margin: 0; background: #fafafa; border-bottom: 1px solid #eee;">Artists</h3>
        <ul class="picker-list">
            {% for artist in artists %}
                <li hx-get="/artist/{{ artist.id }}" hx-target="closest .picker-widget" hx-swap="outerHTML">
                    <div class="picker-list-info">
                        <div class="picker-list-title">{{ artist.name }}</div>
                    </div>
                    <div style="color: #ccc; font-size: 0.8rem;">&rsaquo;</div>
                </li>
            {% endfor %}
        </ul>
    {% endif %}

    {% if albums.length > 0 %}
        <h3 style="padding: 0.5rem 1rem; font-size: 1rem; color: #666; margin: 0; background: #fafafa; border-top: 1px solid #eee; border-bottom: 1px solid #eee;">Albums</h3>
        <ul class="picker-list">
            {% for album in albums %}
                <li hx-get="/album/{{ album.id }}" hx-target="closest .picker-widget" hx-swap="outerHTML">
                    <div class="picker-list-info">
                        <div class="picker-list-title">{{ album.title }}</div>
                        <div class="picker-list-subtitle">{{ album.artist }}</div>
                    </div>
                    <div style="color: #ccc; font-size: 0.8rem;">&rsaquo;</div>
                </li>
            {% endfor %}
        </ul>
    {% endif %}

    {% if playlists.length > 0 %}
        <h3 style="padding: 0.5rem 1rem; font-size: 1rem; color: #666; margin: 0; background: #fafafa; border-top: 1px solid #eee; border-bottom: 1px solid #eee;">Playlists</h3>
        <ul class="picker-list">
            {% for playlist in playlists %}
                <li hx-get="/playlist/{{ playlist.id }}" hx-target="closest .picker-widget" hx-swap="outerHTML">
                    <div class="picker-list-info">
                        <div class="picker-list-title">{{ playlist.name }}</div>
                        <div class="picker-list-subtitle">{{ playlist.songCount }} songs</div>
                    </div>
                    <div style="color: #ccc; font-size: 0.8rem;">&rsaquo;</div>
                </li>
            {% endfor %}
        </ul>
    {% endif %}

    {% if songs.length > 0 %}
        <h3 style="padding: 0.5rem 1rem; font-size: 1rem; color: #666; margin: 0; background: #fafafa; border-top: 1px solid #eee; border-bottom: 1px solid #eee;">Songs</h3>
        <div class="picker-list">
            {% for song in songs %}
                <div class="list-item" style="padding: 0.8rem 1rem;">
                    <div class="song-info">
                        <div class="song-title" style="font-size: 0.95rem;">{{ song.title }}</div>
                        <div class="song-meta" style="font-size: 0.8rem; color: #666;">{{ song.artist }} - {{ song.album }}</div>
                    </div>
                    <div style="font-size: 0.8rem; color: #666; text-align: right;">
                        {{ song.duration | formatDuration }}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    {% if artists.length == 0 and albums.length == 0 and songs.length == 0 and playlists.length == 0 %}
        <div style="padding: 2rem; text-align: center; color: #666;">
            No results found for "{{ query }}"
        </div>
    {% endif %}
{% endblock %}
