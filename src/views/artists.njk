<div class="picker-widget">
    <div class="picker-header">
        <h2>Artists</h2>
    </div>
    <div class="picker-content">
        <ul class="picker-grid">
            {% for artist in artists %}
                <li class="card" hx-get="/artist/{{ artist.id }}" hx-target="closest .picker-widget" hx-swap="outerHTML">
                    {% if artist.coverArt %}
                        <img src="/artwork/{{ artist.coverArt }}" alt="{{ artist.name }}">
                    {% else %}
                        <div style="width: 100%; aspect-ratio: 1; background: #eee; border-radius: 4px; margin-bottom: 0.5rem; display: flex; align-items: center; justify-content: center;">
                            No Image
                        </div>
                    {% endif %}
                    <div style="font-weight: bold; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ artist.name }}</div>
                </li>
            {% else %}
                <li>No artists found.</li>
            {% endfor %}
        </ul>
    </div>
</div>
