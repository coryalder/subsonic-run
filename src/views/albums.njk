{% extends "picker.njk" %}

{% block header %}
    <h2>{% if artist %}{{ artist.name }}{% else %}{{ title | default('Albums') }}{% endif %}</h2>
    {% if artist %}
    <button hx-get="/artists" hx-target="closest .picker-widget" hx-swap="outerHTML" style="font-size: 0.8rem;">&larr; Back</button>
    {% endif %}
{% endblock %}

{% block content %}
    <ul class="picker-list">
        {% for album in albums %}
            <li hx-get="/album/{{ album.id }}" hx-target="closest .picker-widget" hx-swap="outerHTML">
                <div class="picker-list-info">
                    <div class="picker-list-title">{{ album.title }}</div>
                    <div class="picker-list-subtitle">{{ album.year }}</div>
                </div>
                <div style="color: #ccc; font-size: 0.8rem;">&rsaquo;</div>
            </li>
        {% else %}
            <li style="padding: 1rem; color: #666;">No albums found.</li>
        {% endfor %}
    </ul>

    {% if not artist %}
    <div style="display: flex; justify-content: space-between; padding: 1rem; border-top: 1px solid #eee; background: #fafafa;">
        {% if hasPrev %}
            <button hx-get="/albums?offset={{ prevOffset }}" hx-target="closest .picker-widget" hx-swap="outerHTML" style="padding: 0.4rem 0.8rem; border-radius: 4px; border: 1px solid #ddd; background: white; cursor: pointer;">&larr; Previous</button>
        {% else %}
            <div></div>
        {% endif %}
        
        {% if hasMore %}
            <button hx-get="/albums?offset={{ nextOffset }}" hx-target="closest .picker-widget" hx-swap="outerHTML" style="padding: 0.4rem 0.8rem; border-radius: 4px; border: 1px solid #ddd; background: white; cursor: pointer;">Next &rarr;</button>
        {% else %}
            <div></div>
        {% endif %}
    </div>
    {% endif %}
{% endblock %}
