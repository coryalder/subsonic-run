{% extends "layout.njk" %}

{% block content %}
<div style="max-width: 800px; margin: 0 auto;">
    <div style="margin-bottom: 2rem;">
        <a href="/programs" style="text-decoration: none; color: #666; font-size: 1rem;">&larr; Back to Programs</a>
        <h1 style="color: #333; margin: 1rem 0;">Create New Run Program</h1>
    </div>

    <div class="picker-widget">
        <form hx-post="/create-program" hx-target="body" style="padding: 2rem;">
            <div style="margin-bottom: 1.5rem;">
                <label for="name" style="display: block; font-weight: bold; margin-bottom: 0.5rem;">Program Name</label>
                <input type="text" id="name" name="name" placeholder="e.g. 10K Interval Blast" required
                       style="width: 100%; padding: 0.8rem; border-radius: 8px; border: 1px solid #ddd; font-size: 1rem; outline: none;">
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
                <div>
                    <label for="id" style="display: block; font-weight: bold; margin-bottom: 0.5rem;">Program ID (URL safe)</label>
                    <input type="text" id="id" name="id" placeholder="e.g. 10k-blast" required
                           style="width: 100%; padding: 0.8rem; border-radius: 8px; border: 1px solid #ddd; font-size: 1rem; outline: none;">
                </div>
                <div>
                    <label for="difficulty" style="display: block; font-weight: bold; margin-bottom: 0.5rem;">Difficulty (1-5)</label>
                    <input type="number" id="difficulty" name="difficulty" min="1" max="5" value="1" required
                           style="width: 100%; padding: 0.8rem; border-radius: 8px; border: 1px solid #ddd; font-size: 1rem; outline: none;">
                </div>
            </div>

            <div style="margin-bottom: 2rem;">
                <label for="description" style="display: block; font-weight: bold; margin-bottom: 0.5rem;">Description</label>
                <textarea id="description" name="description" rows="3" placeholder="Describe the workout..." required
                          style="width: 100%; padding: 0.8rem; border-radius: 8px; border: 1px solid #ddd; font-size: 1rem; outline: none; font-family: inherit; resize: vertical;"></textarea>
            </div>

            <div style="margin-bottom: 2rem;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                    <label style="display: block; font-weight: bold;">Intervals</label>
                    <button type="button" onclick="addInterval()" 
                            style="background: #1db954; color: white; border: none; padding: 0.5rem 1rem; border-radius: 20px; font-weight: bold; cursor: pointer; font-size: 0.8rem;">
                        + Add Interval
                    </button>
                </div>

                <div id="intervals-container" style="display: flex; flex-direction: column; gap: 1rem;">
                    <!-- Interval rows will be added here -->
                    <div class="interval-row" style="display: grid; grid-template-columns: 2fr 2fr 40px; gap: 1rem; align-items: center; background: #f9f9f9; padding: 1rem; border-radius: 8px; border: 1px solid #eee;">
                        <div>
                            <select name="types" style="width: 100%; padding: 0.6rem; border-radius: 6px; border: 1px solid #ddd;">
                                <option value="warmup">Warmup</option>
                                <option value="run">Run (Fast)</option>
                                <option value="walk">Walk (Slow)</option>
                                <option value="cooldown">Cooldown</option>
                            </select>
                        </div>
                        <div>
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                <input type="number" name="durations" placeholder="Seconds" required min="1"
                                       style="width: 100%; padding: 0.6rem; border-radius: 6px; border: 1px solid #ddd;">
                                <span style="font-size: 0.8rem; color: #666;">sec</span>
                            </div>
                        </div>
                        <div style="text-align: right;">
                            <button type="button" onclick="removeRow(this)" style="background: none; border: none; color: #e74c3c; font-size: 1.2rem; cursor: pointer;">&times;</button>
                        </div>
                    </div>
                </div>
            </div>

            <div style="text-align: right; border-top: 1px solid #eee; padding-top: 2rem;">
                <button type="submit" 
                        style="background: #1db954; color: white; border: none; padding: 1rem 3rem; border-radius: 30px; font-weight: bold; cursor: pointer; font-size: 1.1rem; box-shadow: 0 4px 12px rgba(29, 185, 84, 0.2);">
                    Create Program
                </button>
            </div>
        </form>
    </div>
</div>

<script src="/public/js/create-program.js"></script>
{% endblock %}
