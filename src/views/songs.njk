{% extends "picker.njk" %}

{% block header %}
    <h2 style="font-size: 1rem;">{% if album %}{{ album.artist }} - {{ album.title }}{% else %}{{ playlist.name }}{% endif %}</h2>
    <button hx-get="{% if album %}/artist/{{ album.parent }}{% else %}/playlists{% endif %}" hx-target="closest .picker-widget" hx-swap="outerHTML" style="font-size: 0.8rem;">&larr; Back</button>
{% endblock %}

{% block content_attrs %}style="max-height: 400px; overflow-y: auto; padding: 0;"{% endblock %}

{% block content %}
    {% for song in songs %}
        <div class="list-item">
            <div class="song-info">
                <div class="song-title">{{ song.title }}</div>
                <div class="song-meta">
                    {{ song.artist }} - {{ song.album }}
                    {% if song.bpm %}
                        <span style="margin-left: 0.5rem; font-size: 0.7rem; padding: 2px 6px; border-radius: 10px; background: {% if song.bpm >= 140 %}#ffebee; color: #c62828;{% else %}#e3f2fd; color: #1565c0;{% endif %}">
                            {% if song.bpm >= 140 %}Fast{% else %}Slow{% endif %}
                        </span>
                    {% endif %}
                </div>
            </div>
            <div style="font-size: 0.9rem; color: #666; text-align: right; display: flex; align-items: center; gap: 1rem;">
                <div>
                    {% if song.bpm %}
                        <div style="font-weight: bold; color: #1db954;">{{ song.bpm }} BPM</div>
                    {% endif %}
                    <div>{{ song.duration | formatDuration }}</div>
                </div>
                <button type="button" 
                        class="add-song-btn"
                        style="background: #1db954; color: white; border: none; width: 24px; height: 24px; border-radius: 50%; cursor: pointer; display: none;"
                        onclick="window.addSongToPlaylist({id: '{{ song.id }}', title: '{{ song.title }}', artist: '{{ song.artist }}', duration: {{ song.duration }}, bpm: {{ song.bpm | default(0) }}})">
                    +
                </button>
            </div>
        </div>
    {% else %}
        <div style="padding: 20px;">No songs found.</div>
    {% endfor %}
{% endblock %}
