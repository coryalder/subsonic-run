        <p>Status: <span class="status" style="color: {{ 'green' if connected else 'red' }}">{{ status }}</span></p>
    </div>

    <div id="main-content" hx-get="/artists" hx-trigger="load">
        <p>Loading artists...</p>
    </div>
{% endblock %}

