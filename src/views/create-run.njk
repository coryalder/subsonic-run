{% extends "layout.njk" %}

{% block content %}
<div class="create-run-mode" style="max-width: 1000px; margin: 0 auto;">
    <div style="display: grid; grid-template-columns: 1fr 350px; gap: 2rem; align-items: start;">
        <!-- Left: Form -->
        <div class="picker-widget">
            <div class="picker-header">
                <h2>1. Configure Run</h2>
            </div>
            <div class="picker-content">
                <form id="run-form" hx-post="/start-run" hx-target="closest .create-run-mode" hx-swap="outerHTML">
                    <div style="margin-bottom: 2rem;">
                        <label for="run-name" style="display: block; font-weight: bold; margin-bottom: 0.5rem;">Run Name</label>
                        <input type="text" id="run-name" name="name" placeholder="Morning Run..." required
                               style="width: 100%; padding: 0.8rem; border-radius: 8px; border: 1px solid #ddd; font-size: 1rem; outline: none;">
                    </div>

                    <div style="margin-bottom: 2rem;">
                        <label style="display: block; font-weight: bold; margin-bottom: 1rem;">Choose a Program</label>
                        <div class="grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem;">
                            {% for program in programs %}
                                <label class="program-option">
                                    <input type="radio" name="programId" value="{{ program.id }}" 
                                           data-duration="{{ program.totalDuration }}"
                                           onchange="window.updateTargetDuration(this.dataset.duration)"
                                           style="display: none;" required>
                                    <div class="card" style="height: 100%; text-align: left; transition: all 0.2s; border: 2px solid #eee; padding: 1rem;">
                                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem;">
                                            <div style="font-weight: bold; font-size: 1.1rem; color: #1db954;">{{ program.name }}</div>
                                            <div style="font-size: 0.7rem; background: #eee; padding: 2px 6px; border-radius: 4px; color: #666;">
                                                Diff: {{ program.difficulty }}/5
                                            </div>
                                        </div>
                                        <div style="font-size: 0.85rem; line-height: 1.3; color: #444; margin-bottom: 0.5rem;">{{ program.description }}</div>
                                        <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.75rem; color: #888;">
                                            <span>{{ program.intervals | length }} intervals</span>
                                            <span style="font-weight: bold; color: #666;">{{ program.totalDuration | formatDuration }}</span>
                                        </div>
                                    </div>
                                </label>
                            {% endfor %}
                        </div>
                    </div>

                    <!-- Hidden input for songs -->
                    <div id="selected-songs-inputs"></div>

                    <div style="text-align: right;">
                        <button type="submit" id="submit-btn" disabled
                                style="background: #ccc; color: white; border: none; padding: 1rem 2.5rem; border-radius: 30px; font-weight: bold; cursor: not-allowed; font-size: 1rem;">
                            Start Run &rarr;
                        </button>
                        <div id="duration-warning" style="font-size: 0.8rem; color: #e74c3c; margin-top: 0.5rem;">
                            Playlist must be between 15s shorter and 10min longer than the program.
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Right: Playlist -->
        <div class="picker-widget">
            <div class="picker-header">
                <h2>2. Your Playlist</h2>
            </div>
            <div class="picker-content" style="padding: 1rem;">
                <div style="margin-bottom: 1.5rem; background: #f0f0f0; padding: 1rem; border-radius: 8px;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-weight: bold;">
                        <span>Progress</span>
                        <span id="duration-text">0:00 / 0:00</span>
                    </div>
                    <div style="height: 10px; background: #ddd; border-radius: 5px; overflow: hidden;">
                        <div id="duration-progress" style="height: 100%; width: 0%; background: #1db954; transition: width 0.3s;"></div>
                    </div>
                </div>

                <div id="playlist-items" style="display: flex; flex-direction: column; gap: 0.5rem; max-height: 400px; overflow-y: auto;">
                    <p style="color: #888; text-align: center; padding: 1rem;">No songs selected.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom: Music Picker -->
    <div style="margin-top: 2rem;">
        <div id="music-picker" hx-get="/artists" hx-trigger="load">
            <p>Loading music library...</p>
        </div>
    </div>
</div>

<style>
    .program-option input:checked + .card {
        border-color: #1db954 !important;
        background-color: #f6fff9 !important;
        box-shadow: 0 4px 12px rgba(29, 185, 84, 0.1) !important;
    }
    .program-option .card:hover {
        border-color: #ccc;
    }
    .create-run-mode .add-song-btn {
        display: block !important;
    }
    .playlist-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem 0.8rem;
        background: white;
        border: 1px solid #eee;
        border-radius: 6px;
        font-size: 0.9rem;
    }
    .remove-song {
        color: #e74c3c;
        cursor: pointer;
        font-weight: bold;
    }
</style>

<script>
    (function() {
        let selectedSongs = [];
        let targetDuration = 0;

        window.updateTargetDuration = function(duration) {
            targetDuration = parseInt(duration);
            updateUI();
        };

        window.addSongToPlaylist = function(song) {
            selectedSongs.push(song);
            updateUI();
        };

        window.removeSong = function(index) {
            selectedSongs.splice(index, 1);
            updateUI();
        };

        function formatDuration(seconds) {
            const mins = Math.floor(seconds / 60);
            const secs = Math.floor(seconds % 60);
            return `${mins}:${secs.toString().padStart(2, '0')}`;
        }

        function updateUI() {
            const playlistContainer = document.getElementById('playlist-items');
            const inputsContainer = document.getElementById('selected-songs-inputs');
            const durationText = document.getElementById('duration-text');
            const progressBar = document.getElementById('duration-progress');
            const submitBtn = document.getElementById('submit-btn');
            const warning = document.getElementById('duration-warning');

            const totalDuration = selectedSongs.reduce((sum, s) => sum + s.duration, 0);

            // Update List
            if (selectedSongs.length === 0) {
                playlistContainer.innerHTML = '<p style="color: #888; text-align: center; padding: 1rem;">No songs selected.</p>';
            } else {
                playlistContainer.innerHTML = selectedSongs.map((s, i) => `
                    <div class="playlist-item">
                        <div style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex-grow: 1; margin-right: 1rem;">
                            <strong>${s.title}</strong>
                            <span style="font-size: 0.7rem; margin-left: 0.4rem; padding: 1px 4px; border-radius: 4px; background: ${s.bpm >= 140 ? '#ffebee' : '#e3f2fd'}">
                                ${s.bpm >= 140 ? 'Fast' : 'Slow'}
                            </span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 0.8rem;">
                            <span>${formatDuration(s.duration)}</span>
                            <span class="remove-song" onclick="window.removeSong(${i})">&times;</span>
                        </div>
                    </div>
                `).join('');
            }

            // Update Hidden Inputs
            inputsContainer.innerHTML = selectedSongs.map(s => `
                <input type="hidden" name="songIds" value="${s.id}">
            `).join('');

            // Update Duration Info
            durationText.innerText = `${formatDuration(totalDuration)} / ${formatDuration(targetDuration)}`;
            
            const percentage = targetDuration > 0 ? Math.min(100, (totalDuration / targetDuration) * 100) : 0;
            progressBar.style.width = `${percentage}%`;

            // Validation
            const isValid = targetDuration > 0 && 
                          totalDuration >= (targetDuration - 15) && 
                          totalDuration <= (targetDuration + 600);

            if (isValid) {
                submitBtn.disabled = false;
                submitBtn.style.background = '#1db954';
                submitBtn.style.cursor = 'pointer';
                warning.style.display = 'none';
                progressBar.style.background = '#1db954';
            } else {
                submitBtn.disabled = true;
                submitBtn.style.background = '#ccc';
                submitBtn.style.cursor = 'not-allowed';
                warning.style.display = 'block';
                progressBar.style.background = totalDuration > targetDuration + 600 ? '#e74c3c' : '#1db954';
            }
        }
    })();
</script>
{% endblock %}
