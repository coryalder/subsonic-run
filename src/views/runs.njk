{% extends "layout.njk" %}

{% block content %}
<div class="picker-widget" style="max-width: 900px; margin: 0 auto;">
    <div class="picker-header">
        <h2>Saved Runs</h2>
        <a href="/create-run" style="font-size: 0.9rem; color: #1db954; font-weight: bold; text-decoration: none;">+ New Run</a>
    </div>
    <div class="picker-content">
        {% if runs.length > 0 %}
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                {% for run in runs %}
                    <div class="list-item" style="border: 1px solid #eee; border-radius: 12px; padding: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <div style="font-weight: bold; font-size: 1.2rem; margin-bottom: 0.25rem;">{{ run.name }}</div>
                            <div style="font-size: 0.9rem; color: #666; display: flex; align-items: center; gap: 0.5rem;">
                                <span style="color: #1db954; font-weight: bold;">{{ run.programId }}</span> &bull; 
                                {{ run.startTime | date }} &bull;
                                <span style="padding: 2px 6px; border-radius: 4px; font-size: 0.75rem; font-weight: bold; text-transform: uppercase; 
                                    {% if run.status == 'completed' %}background: #e8f5e9; color: #2e7d32;
                                    {% elif run.status == 'failed' %}background: #ffebee; color: #c62828;
                                    {% else %}background: #fff3e0; color: #ef6c00;{% endif %}">
                                    {{ run.status }}
                                </span>
                            </div>
                        </div>
                        <div style="text-align: right;">
                            <a href="/run/{{ run.id }}" class="card" style="display: inline-block; padding: 0.5rem 1rem; border-radius: 20px; font-size: 0.85rem; color: #1db954; font-weight: bold; text-decoration: none; border: 1px solid #eee;">
                                View Details
                            </a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div style="padding: 3rem; text-align: center; color: #666;">
                <div style="font-size: 3rem; margin-bottom: 1rem;">🏃‍♂️</div>
                <h3>No runs saved yet.</h3>
                <p>Start your first workout to see it here!</p>
                <a href="/create-run" style="display: inline-block; margin-top: 1rem; color: #1db954; font-weight: bold; text-decoration: none;">Create a Run &rarr;</a>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
