{% extends "picker.njk" %}

{% block header %}
    <h2>Artists</h2>
{% endblock %}

{% block content %}
    <ul class="picker-list">
        {% for artist in artists %}
            <li hx-get="/artist/{{ artist.id }}" hx-target="closest .picker-widget" hx-swap="outerHTML">
                <div class="picker-list-info">
                    <div class="picker-list-title">{{ artist.name }}</div>
                </div>
                <div style="color: #ccc; font-size: 0.8rem;">&rsaquo;</div>
            </li>
        {% else %}
            <li style="padding: 1rem; color: #666;">No artists found.</li>
        {% endfor %}
    </ul>
    
    <div style="display: flex; justify-content: space-between; padding: 1rem; border-top: 1px solid #eee; background: #fafafa;">
        {% if hasPrev %}
            <button hx-get="/artists?offset={{ prevOffset }}" hx-target="closest .picker-widget" hx-swap="outerHTML" style="padding: 0.4rem 0.8rem; border-radius: 4px; border: 1px solid #ddd; background: white; cursor: pointer;">&larr; Previous</button>
        {% else %}
            <div></div>
        {% endif %}
        
        {% if hasMore %}
            <button hx-get="/artists?offset={{ nextOffset }}" hx-target="closest .picker-widget" hx-swap="outerHTML" style="padding: 0.4rem 0.8rem; border-radius: 4px; border: 1px solid #ddd; background: white; cursor: pointer;">Next &rarr;</button>
        {% else %}
            <div></div>
        {% endif %}
    </div>
{% endblock %}
