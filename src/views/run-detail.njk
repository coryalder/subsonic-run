{% extends "layout.njk" %}

{% block content %}
<div class="picker-widget" style="max-width: 800px; margin: 0 auto;">
    <div class="picker-header">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <a href="/runs" style="text-decoration: none; color: #666; font-size: 1.2rem;">&larr;</a>
            <h2>Run Details</h2>
        </div>
        <div style="font-size: 0.9rem; color: #666;">ID: {{ run.id }}</div>
    </div>
    <div class="picker-content">
        <div style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
                <h1 style="margin: 0; color: #333;">{{ run.name }}</h1>
                <p style="color: #666; font-size: 1.1rem; margin-top: 0.5rem;">
                    Started on {{ run.startTime | date }}
                </p>
            </div>
            <div style="padding: 0.5rem 1rem; border-radius: 8px; font-weight: bold; text-transform: uppercase;
                {% if run.status == 'completed' %}background: #e8f5e9; color: #2e7d32;
                {% elif run.status == 'failed' %}background: #ffebee; color: #c62828;
                {% else %}background: #fff3e0; color: #ef6c00;{% endif %}">
                Status: {{ run.status }}
            </div>
        </div>

        <div style="background: #f9f9f9; border-radius: 12px; padding: 1.5rem; border: 1px solid #eee; margin-bottom: 2rem;">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                <div style="background: #1db954; color: white; padding: 0.5rem 1rem; border-radius: 20px; font-weight: bold; font-size: 0.9rem;">
                    Program: {{ run.program.name | default(run.programId) }}
                </div>
                {% if run.program.difficulty %}
                <div style="font-size: 0.8rem; color: #666;">Difficulty: {{ run.program.difficulty }}/5</div>
                {% endif %}
            </div>
            <p style="margin: 0 0 1rem 0; line-height: 1.5; color: #444;">
                {{ run.program.description | default("No description available.") }}
            </p>

            {% if run.program.intervals %}
            <div style="margin-top: 1.5rem;">
                <h4 style="margin-bottom: 0.5rem;">Intervals</h4>
                <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                    {% for interval in run.program.intervals %}
                    <div style="display: flex; justify-content: space-between; padding: 0.5rem; background: white; border-radius: 6px; border: 1px solid #eee; font-size: 0.9rem;">
                        <span style="font-weight: bold; color: {% if interval.type == 'run' %}#e74c3c{% elif interval.type == 'walk' %}#3498db{% else %}#95a5a6{% endif %}; text-transform: capitalize;">
                            {{ interval.type }}
                        </span>
                        <span>{{ interval.duration | formatDuration }}</span>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}
        </div>

        <div style="border-top: 1px solid #eee; padding-top: 1.5rem;">
            <h3>Raw Run Data</h3>
            <pre style="background: #222; color: #eee; padding: 1rem; border-radius: 8px; overflow-x: auto; font-size: 0.85rem;">{{ run | dump(2) }}</pre>
        </div>
    </div>
</div>
{% endblock %}
